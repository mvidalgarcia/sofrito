# LLM API Key (required)
LLM_API_KEY=your-api-key-here

# Optional: LLM provider settings
# LLM_BASE_URL=https://opencode.ai/zen/v1
# LLM_MODEL=openai/gpt-oss-120b

# Vercel KV (Upstash Redis) - required for sharing
# Create at: Vercel Dashboard → Storage → Create KV Database
KV_REST_API_URL=your-kv-url
KV_REST_API_TOKEN=your-kv-token

# NextAuth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret
# Create at: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Neon Postgres - required for cross-device recipe persistence
# Provision through Vercel Marketplace, then run: vercel env pull .env.local
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
RECIPE_REPOSITORY=postgres
